# Public — safe to expose to the browser
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server only — never sent to the client
SUPABASE_SERVICE_ROLE_KEY=

# Postgres connection string with PgBouncer (port 6543) for Prisma runtime
DATABASE_URL=

# Direct Postgres connection (port 5432) for Prisma migrations only
DIRECT_URL=
